<robot name="sphere_tennis">
  <link name="object">
    <!-- Main sphere visual -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="sphere_tennis.stl" scale="1.0000E+00 1.0000E+00 1.0000E+00"/>
      </geometry>
      <material name="ball_green">
        <color rgba="0.6 0.8 0.2 1.0"/>
      </material>
    </visual>
    <!-- Small red dot on surface to visualize rotation -->
    <visual>
      <origin xyz="0.034 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.006"/>
      </geometry>
      <material name="dot_red">
        <color rgba="1.0 0.1 0.1 1.0"/>
      </material>
    </visual>
    <!-- Second blue dot on top for extra reference -->
    <visual>
      <origin xyz="0 0 0.034" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.006"/>
      </geometry>
      <material name="dot_blue">
        <color rgba="0.1 0.1 1.0 1.0"/>
      </material>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.057"/>
      <inertia ixx="2.96E-05" ixy="0" ixz="0" iyy="2.96E-05" iyz="0" izz="2.96E-05"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="coacd_allinone.obj" scale="1.0000E+00 1.0000E+00 1.0000E+00"/>
      </geometry>
    </collision>
  </link>
</robot>
